{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-modernization-platform.local/schemas/trust-evidence.schema.json",
  "title": "Trust Evidence Item",
  "type": "object",
  "required": ["name", "status"],
  "properties": {
    "name": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["passed", "warning", "failed", "pending", "skipped"]
    },
    "note": { "type": "string" }
  },
  "additionalProperties": false
}
